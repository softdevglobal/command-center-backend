# Copy to .env and fill in real values. Never commit .env.

# SERVER
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# SUPABASE
SUPABASE_URL=https://your-project.supabase.co
# Caller JWT verification (agent registration)
SUPABASE_ANON_KEY=your_anon_key
# Required for server-side agent registration (auth.admin + inserts)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# app_role label for super-admins (default in code: super_admin). Add enum if needed:
# scripts/add-app-role-super-admin.sql
# SUPABASE_SUPER_ADMIN_ROLE=super_admin

# FIREBASE ADMIN — bmspro-black
FIREBASE_BLACK_PROJECT_ID=
FIREBASE_BLACK_CLIENT_EMAIL=
FIREBASE_BLACK_PRIVATE_KEY=

# FIREBASE ADMIN — bmspro-pink
FIREBASE_PINK_PROJECT_ID=
FIREBASE_PINK_CLIENT_EMAIL=
FIREBASE_PINK_PRIVATE_KEY=

# FIREBASE ADMIN — bmspro-blue (optional)
FIREBASE_BLUE_PROJECT_ID=
FIREBASE_BLUE_CLIENT_EMAIL=
FIREBASE_BLUE_PRIVATE_KEY=

# Optional: JSON instead of the three keys above (per app)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
# FIREBASE_PINK_SERVICE_ACCOUNT=
# FIREBASE_BLUE_SERVICE_ACCOUNT=

# Optional URLs
# BOOKING_ENGINE_URL=

# One-time: POST /api/super-admin/register (header x-setup-secret)
# SETUP_SECRET_KEY=
